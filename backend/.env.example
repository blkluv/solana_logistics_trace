# Copiar a `.env` en esta carpeta (`backend/`) antes de `cargo run`.
# Valores por defecto alineados con `infra/docker-compose.yml`.

DATABASE_URL=postgres://logistics_user:logistics_pass@localhost:5432/logistics_trace

BACKEND_PORT=8000
# Orígenes permitidos para CORS (lista separada por comas). Incluye la URL del frontend.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# RPC de solo lectura para validar transacciones en POST …/sync (misma red que el cliente).
SOLANA_RPC_URL=http://127.0.0.1:8899

# Mismo program id que en cadena y en NEXT_PUBLIC_PROGRAM_ID del frontend.
# Placeholder: el backend trata esto como «no configurado» y los sync devuelven 503.
PROGRAM_ID=ReplaceWithProgramIdAfterDeploy
