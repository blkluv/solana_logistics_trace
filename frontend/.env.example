# Copiar a `.env.local` y ajustar (Next.js carga `.env.local` en desarrollo).
# Variables públicas: van al bundle del navegador; no pongas secretos aquí.

# Red Solana que usa el navegador (Phantom + Connection).
NEXT_PUBLIC_SOLANA_NETWORK=localnet
NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899

# Program ID desplegado en esa red (base58, 32 bytes). Debe coincidir con PROGRAM_ID del backend.
NEXT_PUBLIC_PROGRAM_ID=ReplaceWithProgramIdAfterDeploy

# URL base del API Etapa 1: debe incluir el prefijo /api/v1 (montaje Rocket).
# Sin barra final. Ejemplo con BACKEND_PORT=8000 por defecto:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
